---
/**
 * コンポーネントカタログ（開発・デバッグ用）
 * 本番環境ではトップページへリダイレクト
 */
import Badge from '../components/atoms/Badge.astro';
import Tag from '../components/atoms/Tag.astro';
import Icon from '../components/atoms/Icon.astro';
import KiroIcon from '../components/atoms/KiroIcon.astro';
import DifyIcon from '../components/atoms/DifyIcon.astro';
import OgpCard from '../components/molecules/OgpCard.astro';
import SkillItem from '../components/molecules/SkillItem.astro';
import SocialLink from '../components/molecules/SocialLink.astro';
import TimelineItem from '../components/molecules/TimelineItem.astro';
import { fetchOgp } from '../lib/fetchOgp';
import { getCollection } from 'astro:content';
import ActivitySection from '../components/organisms/ActivitySection.astro';
import OssItemSimple from '../components/molecules/OssItemSimple.astro';
import SpeakingCard from '../components/molecules/SpeakingCard.astro';
import Header from '../components/organisms/Header.astro';
import LogoSvg from '../components/atoms/LogoSvg.astro';
import HeroSection from '../components/organisms/HeroSection.astro';
import CareerTimeline from '../components/organisms/CareerTimeline.astro';
import SkillsGrid from '../components/organisms/SkillsGrid.astro';
import BlogList from '../components/organisms/BlogList.astro';
import PhotoGrid from '../components/organisms/PhotoGrid.astro';
import '../styles/global.css';

if (import.meta.env.PROD) {
  return Astro.redirect('/');
}

const sampleUrls = [
  'https://aws.amazon.com/jp/blogs/news/introducing-powers/',
  'https://findy-tools.io/articles/aws-amplify-gen-2/40',
];

const sampleOgp = await Promise.all(
  sampleUrls.map(async (url) => ({ ...(await fetchOgp(url)), url }))
);

// skills.json からデータ取得してカテゴリ別に分類
const allSkills = await getCollection('skills');
const categories = ['cloud', 'language', 'framework', 'tool', 'other'] as const;
const skillsByCategory = Object.fromEntries(
  categories.map(cat => [cat, allSkills.filter(s => s.data.category === cat)])
);
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>コンポーネントカタログ</title>
  </head>
  <body class="p-8 space-y-12" style="background: oklch(0.98 0.005 120); color: oklch(0.20 0.010 250);">

    <h1 class="text-3xl font-bold border-b pb-4" style="border-color: oklch(0.88 0.008 150);">
      🧩 コンポーネントカタログ
    </h1>

    <!-- ===== Badge ===== -->
    <section class="space-y-4">
      <h2 class="text-xl font-semibold">Badge</h2>
      <div class="flex flex-wrap gap-3 items-center">
        <Badge variant="primary">primary</Badge>
        <Badge variant="secondary">secondary</Badge>
        <Badge variant="ghost">ghost</Badge>
        <Badge variant="primary" size="md">primary md</Badge>
        <Badge variant="secondary" size="md">secondary md</Badge>
      </div>
    </section>

    <!-- ===== Tag ===== -->
    <section class="space-y-4">
      <h2 class="text-xl font-semibold">Tag</h2>
      <div class="flex flex-wrap gap-3 items-center">
        <Tag type="aws" />
        <Tag type="other" />
      </div>
    </section>

    <!-- ===== Icon ===== -->
    <section class="space-y-6">
      <h2 class="text-xl font-semibold">Icon</h2>
      {categories.map(cat => (
        <div>
          <p class="text-xs font-mono mb-3" style="color: oklch(0.55 0.010 250);">{cat}</p>
          <div class="flex flex-wrap gap-6 items-end">
            {skillsByCategory[cat].map(skill => (
              <div class="flex flex-col items-center gap-1">
                {skill.data.icon === 'local:kiro' ? (
                  <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: oklch(0.52 0.24 295);">
                    <KiroIcon size={20} />
                  </div>
                ) : skill.data.icon === 'local:dify' ? (
                  <div class="h-8 flex items-center justify-center">
                    <DifyIcon size={20} />
                  </div>
                ) : skill.data.icon ? (
                  <Icon name={skill.data.icon} size={32} />
                ) : (
                  <span class="w-8 h-8 rounded-full flex items-center justify-center text-white text-xs font-bold" style="background: oklch(0.55 0.12 60);">
                    {skill.data.name.charAt(0)}
                  </span>
                )}
                <span class="text-xs">{skill.data.name}</span>
              </div>
            ))}
          </div>
        </div>
      ))}

      <!-- SNS -->
      <div>
        <p class="text-xs font-mono mb-3" style="color: oklch(0.55 0.010 250);">SNS</p>
        <div class="flex flex-wrap gap-6 items-end">
          <div class="flex flex-col items-center gap-1">
            <Icon name="simple-icons:github" size={32} label="GitHub" />
            <span class="text-xs">GitHub</span>
          </div>
          <div class="flex flex-col items-center gap-1">
            <Icon name="simple-icons:linkedin" size={32} style="color: oklch(0.45 0.17 250);" label="LinkedIn" />
            <span class="text-xs">LinkedIn</span>
          </div>
          <div class="flex flex-col items-center gap-1">
            <Icon name="simple-icons:qiita" size={32} style="color: oklch(0.60 0.17 155);" label="Qiita" />
            <span class="text-xs">Qiita</span>
          </div>
          <div class="flex flex-col items-center gap-1">
            <Icon name="simple-icons:zenn" size={32} style="color: oklch(0.68 0.17 240);" label="Zenn" />
            <span class="text-xs">Zenn</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== カラーパレット ===== -->
    <section class="space-y-4">
      <h2 class="text-xl font-semibold">カラーパレット</h2>
      <div class="flex flex-wrap gap-3">
        {[
          { name: 'bg', value: 'oklch(0.98 0.005 120)' },
          { name: 'surface', value: 'oklch(0.96 0.006 120)' },
          { name: 'primary', value: 'oklch(0.55 0.15 145)' },
          { name: 'secondary', value: 'oklch(0.60 0.08 150)' },
          { name: 'border', value: 'oklch(0.88 0.008 150)' },
          { name: 'text', value: 'oklch(0.20 0.010 250)' },
          { name: 'text-muted', value: 'oklch(0.45 0.010 250)' },
        ].map(({ name, value }) => (
          <div class="flex flex-col items-center gap-1">
            <div
              class="w-16 h-16 rounded-lg border"
              style={`background: ${value}; border-color: oklch(0.88 0.008 150);`}
            />
            <span class="text-xs font-mono">{name}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- ===== Molecules: OgpCard ===== -->
    <section class="space-y-4">
      <h2 class="text-xl font-semibold">OgpCard</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-4xl">
        {sampleOgp.map(({ url, title, description, ogpImage }) => (
          <OgpCard
            externalUrl={url}
            title={title}
            description={description}
            ogpImage={ogpImage}
          />
        ))}
      </div>
    </section>

    <!-- ===== Molecules: SkillItem ===== -->
    <section class="space-y-4">
      <h2 class="text-xl font-semibold">SkillItem</h2>
      <div class="flex flex-wrap gap-1 max-w-2xl">
        {allSkills.map(skill => (
          <SkillItem
            name={skill.data.name}
            icon={skill.data.icon}
            url={skill.data.url}
            category={skill.data.category}
          />
        ))}
      </div>
    </section>

    <!-- ===== Molecules: SocialLink ===== -->
    <section class="space-y-4">
      <h2 class="text-xl font-semibold">SocialLink</h2>
      <div class="flex flex-col gap-2 max-w-xs">
        <SocialLink platform="github" url="https://github.com/yosse95ai" />
        <SocialLink platform="linkedin" url="https://www.linkedin.com/in/hiroaki-yoshimura/" />
        <SocialLink platform="qiita" url="https://qiita.com/yosse95ai" />
        <SocialLink platform="zenn" url="https://zenn.dev/yosse95ai" />
      </div>
    </section>

    <!-- ===== Molecules: TimelineItem ===== -->
    <section class="space-y-4">
      <h2 class="text-xl font-semibold">TimelineItem</h2>
      <div class="max-w-sm">
        <TimelineItem
          organization="Amazon Web Services（AWS）"
          role="Solutions Architect"
          startDate="2023-04"
          endDate={null}
        />
        <TimelineItem
          organization="九州工業大学 大学院"
          role="先端情報工学専攻（情報工学）"
          startDate="2021-04"
          endDate="2023-03"
        />
        <TimelineItem
          organization="九州工業大学"
          role="情報工学部 知能情報工学科"
          startDate="2017-04"
          endDate="2021-03"
          isLast={true}
        />
      </div>
    </section>

    <!-- ===== タイポグラフィ ===== -->
    <section class="space-y-4">
      <h2 class="text-xl font-semibold">タイポグラフィ</h2>
      <div class="space-y-2">
        <p class="text-4xl font-bold">見出し H1 / Heading</p>
        <p class="text-2xl font-semibold">見出し H2 / Subheading</p>
        <p class="text-lg font-medium">見出し H3 / Section</p>
        <p class="text-base">本文テキスト / Body text — AWSソフトウェアエンジニア</p>
        <p class="text-sm" style="color: oklch(0.45 0.010 250);">補足テキスト / Muted text</p>
        <p class="font-mono text-sm">等幅フォント / Monospace: const hello = "world"</p>
      </div>
    </section>

    <!-- ===== Organisms: Header ===== -->
    <section class="space-y-4">
      <h2 class="text-xl font-semibold">Header</h2>
      <p class="text-xs" style="color: oklch(0.55 0.010 250);">※ ページ上部に sticky 表示されているものが実物です</p>
      <div class="border rounded-2xl overflow-hidden" style="border-color: oklch(0.88 0.008 150);">
        <Header />
      </div>

      <!-- ロゴ変更 Before/After -->
      <div class="border rounded-2xl p-4 space-y-4" style="border-color: oklch(0.88 0.008 150);">
        <p class="text-xs font-mono uppercase tracking-wider" style="color: oklch(0.55 0.15 145);">
          Header / ロゴ: テキスト → SVG ロゴ
        </p>
        <div class="grid grid-cols-2 gap-6">
          <div class="space-y-2">
            <p class="text-xs font-mono" style="color: oklch(0.55 0.010 250);">Before: テキスト "hiro.dev"</p>
            <div class="rounded-xl p-4 flex items-center" style="background: oklch(0.96 0.006 120);">
              <a
                href="/"
                class="font-mono text-lg font-semibold no-underline"
                style="color: var(--color-primary);"
              >
                hiro.dev
              </a>
            </div>
          </div>
          <div class="space-y-2">
            <p class="text-xs font-mono" style="color: oklch(0.55 0.010 250);">After: SVG ロゴ（currentColor = primary）</p>
            <div class="rounded-xl p-4 flex items-center" style="background: oklch(0.96 0.006 120);">
              <a href="/" class="no-underline" style="color: var(--color-primary);">
                <LogoSvg height={21} />
              </a>
            </div>
          </div>
        </div>
        <!-- サイズバリエーション -->
        <div class="space-y-2">
          <p class="text-xs font-mono" style="color: oklch(0.55 0.010 250);">サイズバリエーション</p>
          <div class="flex items-end gap-8 flex-wrap rounded-xl p-4" style="background: oklch(0.96 0.006 120);">
            <div class="flex flex-col items-start gap-1">
              <LogoSvg height={14} class="text-[var(--color-primary)]" />
              <span class="text-xs font-mono" style="color: oklch(0.55 0.010 250);">h=14</span>
            </div>
            <div class="flex flex-col items-start gap-1">
              <LogoSvg height={21} class="text-[var(--color-primary)]" />
              <span class="text-xs font-mono" style="color: oklch(0.55 0.010 250);">h=21（デフォルト）</span>
            </div>
            <div class="flex flex-col items-start gap-1">
              <LogoSvg height={28} class="text-[var(--color-primary)]" />
              <span class="text-xs font-mono" style="color: oklch(0.55 0.010 250);">h=28</span>
            </div>
            <div class="flex flex-col items-start gap-1">
              <LogoSvg height={36} class="text-[var(--color-primary)]" />
              <span class="text-xs font-mono" style="color: oklch(0.55 0.010 250);">h=36</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== Organisms: HeroSection ===== -->
    <section class="space-y-4">
      <h2 class="text-xl font-semibold">HeroSection</h2>
      <div class="max-w-2xl">
        <HeroSection />
      </div>
    </section>

    <!-- ===== Organisms: CareerTimeline ===== -->
    <section class="space-y-4">
      <h2 class="text-xl font-semibold">CareerTimeline</h2>
      <CareerTimeline />
    </section>

    <!-- ===== Organisms: SkillsGrid ===== -->
    <section class="space-y-4">
      <h2 class="text-xl font-semibold">SkillsGrid</h2>
      <div class="max-w-3xl">
        <SkillsGrid />
      </div>
    </section>

    <!-- ===== Organisms: BlogList ===== -->
    <section class="space-y-4">
      <h2 class="text-xl font-semibold">BlogList</h2>
      <BlogList />
    </section>

    <!-- ===== Organisms: PhotoGrid ===== -->
    <section class="space-y-4">
      <h2 class="text-xl font-semibold">PhotoGrid</h2>
      <PhotoGrid />
    </section>

    <!-- ===== Molecules: OssItemSimple ===== -->
    <section class="space-y-4">
      <h2 class="text-xl font-semibold">OssItemSimple</h2>

      <OssItemSimple
        repo="aws-samples/dify-self-hosted-on-aws"
        url="https://github.com/aws-samples/dify-self-hosted-on-aws"
        description="AWS 上に Dify をセルフホストするための CDK テンプレート。コントリビューターとして機能追加・改善に参加。"
      />
    </section>

    <!-- ===== Molecules: SpeakingCard ===== -->
    <section class="space-y-4">
      <h2 class="text-xl font-semibold">SpeakingCard</h2>
      <div class="flex gap-4 overflow-x-auto pb-2 -mx-2 px-2" style="scrollbar-width: thin; scrollbar-color: var(--color-border) transparent;">
        <div class="shrink-0 w-72 space-y-2">
          <p class="text-xs font-mono" style="color: var(--color-text-muted);">url なし（グラデーションプレースホルダー）</p>
          <SpeakingCard
            id="aws-innovate-fy24q3"
            title="フロントエンドエンジニアのための次世代開発者体験 〜 爆速 Web/モバイルアプリケーション開発 〜"
            event="FY24 Q3 AWS Innovate MMB T4-5"
            date="2024"
            url={null}
            description="2024 年 9 月 26 日に開催された AWS Innovate にて、Amplify Gen 2 を用いてアプリケーション開発を加速させるというテーマで登壇しました。"
          />
        </div>
        <div class="shrink-0 w-72 space-y-2">
          <p class="text-xs font-mono" style="color: var(--color-text-muted);">url あり（イベントページリンク）</p>
          <SpeakingCard
            id="hospital-show-2024"
            title="AWS ではじめる生成 AI 活用 〜 セキュアに医療情報を取り扱う 〜"
            event="2024 年 国際モダンホスピタルショウ"
            date="2024"
            url="https://www.cbnews.jp/news/entry/20240821194911"
            description="2024 年 7 月に開催された、国際モダンホスピタルショウ 2024 にて、AWS の生成 AI サービスである Amazon Bedrock とヘルスケアにおける生成 AI 活用事例をテーマに登壇しました。"
          />
        </div>
        <div class="shrink-0 w-72 space-y-2">
          <p class="text-xs font-mono" style="color: var(--color-text-muted);">url あり（PDF リンク）</p>
          <SpeakingCard
            id="radiology-2025"
            title="クラウド環境を用いた AI/ML 開発を体感"
            event="2025 年 放射線学会 ハンズオンセミナー"
            date="2025"
            url="https://www.jsrt.or.jp/gmeeting/soukai81/files/2025/03/f10b04999721383c06e48c220c1f012e.pdf"
            description="2025 年 4 月 12 日に開催された、放射線学会のハンズオンセミナーにて、クラウド環境を用いた AI/ML 開発と題して、放射線科医や医師、ヘルステックベンダー向けに 2 時間の生成 AI に関する座学と実践ハンズオンを開催しました。"
          />
        </div>
      </div>
    </section>

    <!-- ===== Organisms: ActivitySection ===== -->
    <section class="space-y-4">
      <h2 class="text-xl font-semibold">ActivitySection</h2>
      <ActivitySection />
    </section>

  </body>
</html>
