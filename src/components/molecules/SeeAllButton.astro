---
export interface Props {
  href: string;
}
const { href } = Astro.props;
---

<a
  {href}
  class="btn-see-all shrink-0 w-40 self-stretch rounded-2xl flex flex-col items-center justify-center gap-2 no-underline font-semibold text-sm md:text-base bg-primary-content text-primary border border-primary"
>
  <span class="text-lg">→</span>
  <span class="text-sm md:text-base font-semibold">全てを見る</span>
</a>

<style>
  .btn-see-all:hover {
    background: oklch(from var(--color-primary) l c h / 0.12) !important;
  }
</style>
