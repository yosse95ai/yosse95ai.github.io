---
import Header from '../organisms/Header.astro';
import ParticlesFloating from '../atoms/ParticlesFloating.astro';
import { ClientRouter } from 'astro:transitions';
import '../../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'hiro.dev',
  description = 'AWS の Solutions Architect として活動するエンジニアのポートフォリオサイトです。',
} = Astro.props;

const siteUrl = 'https://yosse95ai.github.io';
const ogImage = `${siteUrl}/images/icon.png`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- OGP -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={siteUrl} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- View Transitions -->
    <ClientRouter />
  </head>
  <body>
    <ParticlesFloating count={80} />
    <Header />
    <main>
      <slot />
    </main>
    <footer
      class="mt-16 border-t border-border py-6 text-center text-xs text-secondary"
    >
      © {new Date().getFullYear()} Hiroaki Yoshimura
    </footer>

    <script>
      function initSkeletons() {
        document.querySelectorAll('.skeleton-img').forEach((wrapper) => {
          const img = wrapper.querySelector('img');
          if (!img) return;

          if (img.complete && img.naturalWidth > 0) {
            wrapper.setAttribute('data-loaded', '');
            return;
          }

          img.addEventListener('load', () => {
            wrapper.setAttribute('data-loaded', '');
          }, { once: true });

          img.addEventListener('error', () => {
            wrapper.setAttribute('data-loaded', '');
          }, { once: true });
        });
      }

      // 初回 + View Transitions 後
      initSkeletons();
      document.addEventListener('astro:page-load', initSkeletons);
    </script>

    {/* Cloudflare Web Analytics — 本番のみ */}
    {import.meta.env.PROD && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon='{"token": "16015c0c8c9c476f8a7680967d572bd5"}'
      />
    )}
  </body>
</html>
