---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import iconSrc from '../../assets/icon.jpg';

const allCareer = await getCollection('career');
// endDate が null = 現職
const current = allCareer.find(c => c.data.endDate === null);
---

<section
  class="rounded-3xl p-8 flex flex-col gap-6 w-full"
  style="background: var(--color-surface); box-shadow: 0 1px 4px var(--color-shadow-sm);"
>
  <!-- プロフィール写真 + 名前 -->
  <div class="flex items-center gap-4">
    <Image
      src={iconSrc}
      alt="プロフィール写真"
      width={144}
      height={144}
      class="rounded-2xl object-cover shrink-0 w-[72px] h-[72px]"
      style="box-shadow: 0 2px 8px var(--color-shadow-md);"
    />
    <div>
      {current && (
        <p class="text-sm md:text-base font-mono mb-0.5" style="color: var(--color-primary);">
          {current.data.role}
        </p>
      )}
      <h1 class="text-2xl md:text-3xl font-bold leading-tight text-base-100">
        Hiroaki Yoshimura
      </h1>
      {current && (
        <p class="text-sm md:text-base" style="color: var(--color-text-muted);">
          {current.data.organization}
        </p>
      )}
    </div>
  </div>

  <!-- 自己紹介 -->
  {current?.data.description && (
    <p class="text-sm md:text-base leading-relaxed" style="color: var(--color-text-body);">
      {current.data.description}
    </p>
  )}
</section>
