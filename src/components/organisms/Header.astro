---
import LogoSvg from '../atoms/LogoSvg.astro';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/history', label: 'History' },
];

const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 w-full border-b border-border bg-header-bg backdrop-blur-sm"
>
  <div class="px-4 sm:px-6">
    <div class="flex h-14 items-center justify-between">
      <!-- ロゴ -->
      <a
        href="/"
        class="no-underline text-primary"
        aria-label="ホームへ戻る"
      >
        <LogoSvg height={21} />
      </a>

      <!-- ナビゲーション -->
      <nav aria-label="メインナビゲーション">
        <ul class="flex items-center gap-1 list-none m-0 p-0">
          {navLinks.map(({ href, label }) => {
            const isActive = href === '/'
              ? currentPath === '/'
              : currentPath.startsWith(href);
            return (
              <li>
                <a
                  href={href}
                  class:list={[
                    'rounded-lg px-3 py-1.5 text-sm md:text-base font-medium transition-colors no-underline',
                    isActive
                      ? 'bg-nav-active-bg text-nav-active-text'
                      : 'text-text-muted',
                  ]}
                  aria-current={isActive ? 'page' : undefined}
                >
                  {label}
                </a>
              </li>
            );
          })}
        </ul>
      </nav>
    </div>
  </div>
</header>
