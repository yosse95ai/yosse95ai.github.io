---
import TimelineItem from '../molecules/TimelineItem.astro';
import { getCollection } from 'astro:content';

export interface Props {
  /** true のとき全件表示、false のとき最新4件のみ */
  showAll?: boolean;
}

const { showAll = false } = Astro.props;

const allCareer = await getCollection('career');
// startDate 降順（最新が上）
const sorted = allCareer.sort(
  (a, b) => b.data.startDate.localeCompare(a.data.startDate)
);
const items = showAll ? sorted : sorted.slice(0, 4);
const hasMore = !showAll;

function formatDate(ym: string): string {
  const [year, month] = ym.split('-');
  return `${year} 年 ${parseInt(month)} 月`;
}
---

<section
  class="rounded-3xl p-6 flex flex-col gap-4 w-full"
  style="background: var(--color-surface); box-shadow: 0 1px 4px var(--color-shadow-sm);"
>
  <h2 class="text-sm md:text-base font-semibold uppercase tracking-wider" style="color: var(--color-primary);">
    Career
  </h2>

  {showAll ? (
    <>
      {/* PC: CSS Grid レイアウト（md 以上） */}
      <div class="hidden md:grid gap-y-0 relative" style="grid-template-columns: auto 1px 1fr;">
        {items.map((item, i) => {
          const isFirst = i === 0;
          const isLast = i === items.length - 1;
          const start = formatDate(item.data.startDate);
          const end = item.data.endDate ? formatDate(item.data.endDate) : '現在';
          return (
            <>
              {/* 日付行（col-span-3） */}
              <div class="relative flex gap-4 col-span-3 pb-1">
                {isFirst && !isLast && (
                  <div class="absolute left-[5px] top-4 bottom-0 w-px" style="background: var(--color-border);"></div>
                )}
                {!isFirst && !isLast && (
                  <div class="absolute left-[5px] top-0 bottom-0 w-px" style="background: var(--color-border);"></div>
                )}
                {isLast && !isFirst && (
                  <div class="absolute left-[5px] top-0 bottom-[calc(100%-0.375rem)] w-px" style="background: var(--color-border);"></div>
                )}
                <div class="w-3 h-3 rounded-full shrink-0 mt-1 z-10" style="background: var(--color-primary);"></div>
                <p class="text-sm md:text-base font-mono" style="color: var(--color-primary);">{start} — {end}</p>
              </div>
              {/* 左カラム: org + role */}
              <div class={`pl-7 pr-4 pb-6 ${!isLast ? 'relative' : ''}`}>
                {!isLast && (
                  <div class="absolute left-[5px] top-0 bottom-0 w-px" style="background: var(--color-border);"></div>
                )}
                <p class="font-semibold text-base md:text-lg leading-snug text-base-100">{item.data.organization}</p>
                <p class="text-sm md:text-base mt-0.5" style="color: var(--color-text-muted);">{item.data.role}</p>
              </div>
              {/* セパレーター */}
              <div style="background: var(--color-border);"></div>
              {/* 右カラム: description */}
              <div class="pl-4 pb-6 flex items-start">
                {item.data.description && (
                  <p class="text-sm md:text-base leading-relaxed" style="color: var(--color-text-body);">{item.data.description}</p>
                )}
              </div>
            </>
          );
        })}
      </div>

      {/* モバイル: 縦積み（md 未満） */}
      <div class="md:hidden">
        {items.map((item, i) => (
          <TimelineItem
            organization={item.data.organization}
            role={item.data.role}
            startDate={item.data.startDate}
            endDate={item.data.endDate ?? null}
            description={item.data.description}
            isLast={i === items.length - 1}
          />
        ))}
      </div>
    </>
  ) : (
    <div class="flex-1 max-w-2xl">
      {items.map((item, i) => (
        <TimelineItem
          organization={item.data.organization}
          role={item.data.role}
          startDate={item.data.startDate}
          endDate={item.data.endDate ?? null}
          isLast={i === items.length - 1}
        />
      ))}
    </div>
  )}

  {hasMore && (
    <a
      href="/history"
      class="inline-flex items-center gap-1 text-xs md:text-sm font-medium transition-all duration-200 hover:gap-2 no-underline self-start"
      style="color: var(--color-primary);"
    >
      全てを見る
      <span aria-hidden="true">→</span>
    </a>
  )}
</section>
